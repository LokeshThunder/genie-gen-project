rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── HELPER FUNCTIONS ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole() {
      // Role is ALWAYS sourced from Firestore — never from client-supplied claims
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? getUserData().role
        : 'worker';
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    function isSuperAdmin() {
      return isAuthenticated() && getRole() == 'super_admin';
    }

    function isAdminOrSuperAdmin() {
      return isAdmin() || isSuperAdmin();
    }

    // Prevents workers from self-promoting their role to admin/super_admin
    function roleNotEscalated() {
      return !request.resource.data.keys().hasAny(['role'])
        || !(request.resource.data.role in ['admin', 'super_admin']);
    }

    // ─── USERS ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Only the profile owner or an admin can read any user profile
      // This prevents attackers from enumerating all user data
      allow read: if isOwner(userId) || isAdminOrSuperAdmin();

      // Users can create / update only their own profile,
      // but are BLOCKED from self-promoting to admin
      allow create: if isOwner(userId) && roleNotEscalated();
      allow update: if isOwner(userId) && roleNotEscalated();

      // Only admins can delete user records
      allow delete: if isAdminOrSuperAdmin();
    }

    // ─── JOBS ─────────────────────────────────────────────────────────────────
    match /jobs/{jobId} {
      // Any authenticated user can browse jobs
      allow read: if isAuthenticated();
      // Only admins can post, edit, or remove jobs
      allow create, update, delete: if isAdminOrSuperAdmin();
    }

    // ─── APPLICATIONS ─────────────────────────────────────────────────────────
    match /applications/{appId} {
      // Workers can read only their own applications; admins can read all
      allow read: if isAuthenticated()
        && (resource.data.workerId == request.auth.uid || isAdminOrSuperAdmin());

      // On creation: workerId must equal the caller's UID and status MUST be 'Pending'
      // This prevents a worker applying as someone else, or self-approving their application
      allow create: if isAuthenticated()
        && request.resource.data.workerId == request.auth.uid
        && request.resource.data.status == 'Pending';

      // Workers can update their own applications (e.g. add a note)
      // but are BLOCKED from changing the 'status' field — only admins control status
      allow update: if isAuthenticated() && (
        isAdminOrSuperAdmin() ||
        (resource.data.workerId == request.auth.uid
          && !(request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])))
      );

      // Only admins can delete application records
      allow delete: if isAdminOrSuperAdmin();

      // Tasks sub-collection: scoped to the application owner or admins
      match /tasks/{taskId} {
        allow read, write: if isAuthenticated()
          && (get(/databases/$(database)/documents/applications/$(appId)).data.workerId == request.auth.uid
              || isAdminOrSuperAdmin());
      }
    }

    // ─── ATTENDANCE ───────────────────────────────────────────────────────────
    match /attendance/{atId} {
      // Workers see only their own records; admins see all
      allow read: if isAuthenticated()
        && (resource.data.workerId == request.auth.uid || isAdminOrSuperAdmin());

      // Workers can only create attendance records for themselves
      allow create: if isAuthenticated()
        && request.resource.data.workerId == request.auth.uid;

      // Workers can update their own record (e.g. checkout); admins can update any
      allow update: if isAuthenticated()
        && (resource.data.workerId == request.auth.uid || isAdminOrSuperAdmin());

      // Only admins can delete attendance records
      allow delete: if isAdminOrSuperAdmin();
    }

    // ─── REVIEWS ──────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      // Reviews are publicly readable by any authenticated user
      allow read: if isAuthenticated();

      // A user can only create a review attributed to themselves
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid;

      // Only the author or an admin can edit / delete a review
      allow update, delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isAdminOrSuperAdmin());
    }

    // ─── RATINGS ──────────────────────────────────────────────────────────────
    match /ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isAdminOrSuperAdmin());
    }

    // ─── DISPUTES ─────────────────────────────────────────────────────────────
    match /disputes/{disputeId} {
      allow read, write: if isAuthenticated()
        && (resource == null
            || resource.data.userId == request.auth.uid
            || isAdminOrSuperAdmin());
    }

    // ─── WORKER LOCATIONS ─────────────────────────────────────────────────────
    match /worker_locations/{locationId} {
      // Location data is sensitive — only the worker themselves or admins can access it
      allow read, write: if isAuthenticated()
        && (resource == null
            || resource.data.userId == request.auth.uid
            || isAdminOrSuperAdmin());
    }
  }
}