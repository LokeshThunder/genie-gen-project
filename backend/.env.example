# Job Genie Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env with real secrets — use GitHub Secrets for CI/CD
# ─────────────────────────────────────────────────────────────────────────────

# ─── FIREBASE CONFIGURATION ──────────────────────────────────────────────────
# Get these from Firebase Console: https://console.firebase.google.com
# Project Settings → Service Accounts → Generate New Private Key

VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=1:your-app-id:web:your-web-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-your-measurement-id

# ─── GOOGLE AUTHENTICATION ──────────────────────────────────────────────────
# Get from Google Cloud Console: https://console.cloud.google.com
# Create OAuth 2.0 Client ID (Web Application)

VITE_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id-here.apps.googleusercontent.com

# ─── AI & EXTERNAL SERVICES ─────────────────────────────────────────────────
# Gemini API: https://makersuite.google.com/app/apikey
# Leave empty to disable AI features in development

VITE_GEMINI_API_KEY=
VITE_SENTRY_DSN=

# ─── DEVELOPMENT MODE ────────────────────────────────────────────────────────
# true  = Use MockFirestore (local in-memory data, no Firebase needed)
# false = Use real Firestore (requires valid Firebase project)

VITE_USE_MOCK=true

# ─── E2E/TEST MODE ───────────────────────────────────────────────────────────
# true  = Enable E2E test mode with mock users (development only)
# false = Disabled (production)

VITE_E2E_MODE=true

# ─── FIREBASE EMULATOR ───────────────────────────────────────────────────────
# Use local Firebase Emulator for development (run: firebase emulators:start)

VITE_USE_FIREBASE_EMULATOR=false
VITE_FIREBASE_EMULATOR_HOST=localhost  # Use 10.0.2.2 for Android emulator
